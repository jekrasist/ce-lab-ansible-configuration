# {{ app_name }} configuration
# Environment: {{ environment }}
# Generated by Ansible — do not edit manually

[application]
name = {{ app_name }}
port = {{ app_port }}
environment = {{ app_env }}
log_directory = /opt/{{ app_name }}/logs

[server]
workers = {{ nginx_worker_processes }}
server_name = {{ nginx_server_name }}
max_connections = {% if environment == 'production' %}1024{% else %}256{% endif %}

[logging]
level = {% if environment == 'production' %}WARNING{% else %}DEBUG{% endif %}

log_file = /opt/{{ app_name }}/logs/{{ app_name }}.log

